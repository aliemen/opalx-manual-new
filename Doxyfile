PROJECT_NAME           = "OPALX"
PROJECT_BRIEF          = "Performance-portable accelerator simulation framework"
OUTPUT_DIRECTORY       = _site/api
INPUT                  = $(OPALX_SOURCE_DIR)/src
RECURSIVE              = YES
FILE_PATTERNS          = *.h *.hpp *.cpp
EXTRACT_ALL            = NO
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = NO
GENERATE_HTML          = YES
HTML_OUTPUT            = html
GENERATE_LATEX         = NO
GENERATE_TREEVIEW      = YES
FULL_SIDEBAR           = YES
HAVE_DOT               = NO
USE_MATHJAX            = YES
QUIET                  = YES
WARN_IF_UNDOCUMENTED   = NO
WARN_IF_DOC_ERROR      = YES
WARN_LOGFILE           = _site/api/doxygen-warnings.log
